import random
def guess(x):
    guess=0
    guess_number=random.randint(1,x+1)
    while guess != guess_number:
        guess=int(input('enter guess number: '))
        if guess < guess_number:
            if guess_number < 5:
                print('it is too low')
            else:
                print('it is low')
            
        
        elif guess > guess_number:
            if guess > 5:
                print('it is too high ')
            else:
                print('it high')

    print(f'congratulations your {guess} is matched to {guess_number}')
guess(10)
